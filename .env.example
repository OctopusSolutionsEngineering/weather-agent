# ===== Bootstrap (always from env) =====

# Azure App Configuration (NEW)
USE_APP_CONFIGURATION=false
AZURE_APPCONFIG_ENDPOINT=https://my-weather-appconfig.azconfig.io
APPCONFIG_LABEL=prod                # 'dev', 'staging', 'prod'
APPCONFIG_REFRESH_INTERVAL=30       # seconds

# Azure Key Vault (used standalone OR via App Config references)
USE_KEY_VAULT=false
AZURE_KEY_VAULT_URL=https://my-weather-vault.vault.azure.net

# ===== Local Development Overrides =====
# (only used when App Config + Key Vault are disabled)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO

CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
0007c11d-6e78-4061-a512-baf8861a6552
https://demo-octopus-app.vault.azure.net/
https://demo-octopus-app.azconfig.io