# ===== App =====
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO

# ===== Key Vault =====
USE_KEY_VAULT=false
AZURE_KEY_VAULT_URL=

# ===== Caching =====
# Backend: 'memory' (default, single-pod) or 'redis' (multi-pod)
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_MAX_SIZE=1000

# TTLs in seconds
CACHE_TTL_GEOCODING=86400          # 24h (coordinates rarely change)
CACHE_TTL_CURRENT_WEATHER=600      # 10min (current conditions)
CACHE_TTL_FORECAST=1800            # 30min (forecasts)
CACHE_TTL_AGENT_RESPONSE=300       # 5min (full agent responses)

# Toggles
ENABLE_TOOL_CACHE=true
ENABLE_RESPONSE_CACHE=true
