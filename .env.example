# ===== Local Dev: use env vars directly =====
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO

# ===== Production: use Azure Key Vault =====
USE_KEY_VAULT=false
AZURE_KEY_VAULT_URL=https://my-weather-vault.vault.azure.net

# Optional: explicit auth (DefaultAzureCredential auto-detects these)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=